# Neon Postgres connection string (free tier — https://neon.tech)
# Must have the `vector` extension enabled: CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL="postgresql://user:password@ep-example.neon.tech/myawesome?sslmode=require"

# GitHub OAuth app (https://github.com/settings/developers)
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Used by Auth.js to sign/encrypt session data — generate with `openssl rand -base64 33`
AUTH_SECRET=""

# Anthropic API key (https://console.anthropic.com) — used only for the Haiku ranking pass
ANTHROPIC_API_KEY=""

# Optional: a personal GitHub token for higher-rate-limit discovery/ingestion scripts
# (unauthenticated GitHub API calls are limited to 60/hr; a token bumps this to 5000/hr)
GITHUB_TOKEN=""
